{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20
  },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release Preset (Windows / MSVC)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Preset (Windows, RelWithDebInfo + Profiling)",
      "inherits": "release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "debug-profile",
      "displayName": "Debug Profile Preset (Windows, terminal frame profiling)",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/out/build-profile",
      "cacheVariables": {
        "INFERNUX_FRAME_PROFILE_TERMINAL": "ON"
      }
    },
    {
      "name": "release-macos",
      "displayName": "Release Preset (macOS / Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-macos",
      "displayName": "Debug Preset (macOS, RelWithDebInfo + Profiling)",
      "inherits": "release-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "release-linux",
      "displayName": "Release Preset (Linux / Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-linux",
      "displayName": "Debug Preset (Linux)",
      "inherits": "release-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "debug-profile",
      "configurePreset": "debug-profile",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "release-macos",
      "configurePreset": "release-macos"
    },
    {
      "name": "debug-macos",
      "configurePreset": "debug-macos"
    },
    {
      "name": "release-linux",
      "configurePreset": "release-linux"
    },
    {
      "name": "debug-linux",
      "configurePreset": "debug-linux"
    },
    {
      "name": "format",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "clang_format"
      ]
    },
    {
      "name": "wiki",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "build_wiki_html"
      ]
    },
    {
      "name": "packaging",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "infernux_hub"
      ]
    },
    {
      "name": "packaging-installer",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "infernux_hub_installer"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "RelWithDebInfo",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-macos",
      "configurePreset": "release-macos",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-macos",
      "configurePreset": "debug-macos",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-linux",
      "configurePreset": "release-linux",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-linux",
      "configurePreset": "debug-linux",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
